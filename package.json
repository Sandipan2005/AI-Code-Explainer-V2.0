    "preview": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& './node_modules/.bin/vite.ps1' preview\""
  },
  "dependencies": {
    "@google/genai": "^1.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
