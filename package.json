{
  "name": "code-explainer-and-debugger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& './node_modules/.bin/vite.ps1'\"",
